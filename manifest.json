{
  "manifest_version": 3,
  "name": "GitScope",
  "version": "1.1.1",
  "description": "GitHub Profile & Repository Analyzer",
  "permissions": ["activeTab", "storage", "sidePanel"],
  "host_permissions": ["https://api.github.com/*", "https://github.com/*"],
  "action": {
    "default_title": "Open GitScope"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
